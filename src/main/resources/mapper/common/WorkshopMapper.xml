<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lei.mes.mapper.common.WorkshopMapper">

    <!-- 分页查询车间 -->
    <select id="getWorkshopPage" resultType="com.lei.mes.vo.common.WorkshopVO">
        SELECT w.id, w.workshop_code, w.workshop_name, w.location,
               w.status, w.created_at, w.updated_at
        FROM workshop w
        WHERE w.is_delete = 0
        <if test="workshopName != null and workshopName != ''">
            AND w.workshop_name LIKE CONCAT('%', #{workshopName}, '%')
        </if>
        ORDER BY w.created_at DESC
    </select>

    <!-- 查询车间详情（含产线） -->
    <select id="getWorkshopDetail" resultMap="WorkshopDetailResultMap">
        SELECT w.id, w.workshop_code, w.workshop_name, w.location,
               w.status, w.created_at, w.updated_at,
               pl.id AS lineId, pl.line_code, pl.line_name,
               pl.workshop_id, pl.capacity_per_day, pl.status AS lineStatus,
               pl.created_at AS lineCreated_at, pl.updated_at AS lineUpdated_at
        FROM workshop w
        LEFT JOIN production_line pl ON w.id = pl.workshop_id AND pl.is_delete = 0
        WHERE w.id = #{id} AND w.is_delete = 0
        ORDER BY pl.sort_order ASC
    </select>

    <!-- 查询所有车间（下拉选择用） -->
    <select id="getAllWorkshops" resultType="com.lei.mes.vo.common.WorkshopVO">
        SELECT w.id, w.workshop_code, w.workshop_name
        FROM workshop w
        WHERE w.is_delete = 0
        ORDER BY w.workshop_code ASC
    </select>

    <resultMap id="WorkshopDetailResultMap" type="com.lei.mes.vo.common.WorkshopVO">
        <id property="id" column="id"/>
        <result property="workshopCode" column="workshop_code"/>
        <result property="workshopName" column="workshop_name"/>
        <result property="location" column="location"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>

        <collection property="lines" ofType="com.lei.mes.vo.common.ProductionLineVO">
            <id property="id" column="lineId"/>
            <result property="lineCode" column="line_code"/>
            <result property="lineName" column="line_name"/>
            <result property="workshopId" column="workshop_id"/>
            <result property="capacityPerDay" column="capacity_per_day"/>
            <result property="status" column="lineStatus"/>
            <result property="createdAt" column="lineCreated_at"/>
            <result property="updatedAt" column="lineUpdated_at"/>
        </collection>
    </resultMap>

</mapper>
