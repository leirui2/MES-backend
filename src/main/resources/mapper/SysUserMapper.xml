<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lei.mes.mapper.user.SysUserMapper">

    <resultMap id="BaseResultMap" type="com.lei.mes.entity.user.SysUser">
            <id property="id" column="id" />
            <result property="username" column="username" />
            <result property="password" column="password" />
            <result property="realName" column="real_name" />
            <result property="phone" column="phone" />
            <result property="email" column="email" />
            <result property="avatar" column="avatar" />
            <result property="isDelete" column="is_delete" />
            <result property="status" column="status" />
            <result property="deptId" column="dept_id" />
            <result property="lastLoginTime" column="last_login_time" />
            <result property="lastLoginIp" column="last_login_ip" />
            <result property="createdAt" column="created_at" />
            <result property="updatedAt" column="updated_at" />
    </resultMap>

    <sql id="Base_Column_List">
        id,username,password,real_name,phone,email,avatar,is_delete,status,dept_id,last_login_time,last_login_ip,
        created_at,updated_at
    </sql>



    <!-- 根据id查询用户及角色和菜单 -->
    <resultMap id="UserVOResultMap" type="com.lei.mes.vo.user.UserVO">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="realName" column="realName"/>
        <result property="phone" column="phone"/>
        <result property="email" column="email"/>
        <result property="avatar" column="avatar"/>
        <result property="status" column="status"/>

        <!-- 角色列表 -->
        <collection property="roles" ofType="com.lei.mes.vo.user.RoleVO">
            <id property="roleId" column="roleId"/>
            <result property="roleName" column="roleName"/>
            <result property="roleCode" column="roleCode"/>

            <!-- 菜单列表 -->
            <collection property="menus" ofType="com.lei.mes.vo.user.MenuVO">
                <id property="menuId" column="menuId"/>
                <result property="menuName" column="menuName"/>
                <result property="menuCode" column="menuCode"/>
                <result property="url" column="url"/>
                <result property="icon" column="icon"/>
                <result property="sortOrder" column="sortOrder"/>
                <result property="perms" column="perms"/>
            </collection>
        </collection>
    </resultMap>

    <select id="getUserVoById" resultMap="UserVOResultMap">
        SELECT
            u.id AS id,
            u.username AS username,
            u.real_name AS realName,
            u.phone AS phone,
            u.email AS email,
            u.avatar AS avatar,
            u.status AS status,
            r.id AS roleId,
            r.role_name AS roleName,
            r.role_code AS roleCode,
            m.id AS menuId,
            m.menu_name AS menuName,
            m.menu_code AS menuCode,
            m.url AS url,
            m.icon AS icon,
            m.sort_order AS sortOrder,
            m.perms AS perms
        FROM sys_user u
                 LEFT JOIN sys_user_role ur ON u.id = ur.user_id
                 LEFT JOIN sys_role r ON ur.role_id = r.id AND r.is_delete = 0
                 LEFT JOIN sys_role_menu rm ON r.id = rm.role_id
                 LEFT JOIN sys_menu m ON rm.menu_id = m.id AND m.is_delete = 0
        WHERE u.id = #{userId} AND u.is_delete = 0
    </select>


    <!-- 分页查询用户VO -->
    <!-- 用户详情结果映射 -->
    <resultMap id="userDetailResultMap" type="com.lei.mes.vo.user.UserVO">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="real_name" property="realName"/>
        <result column="phone" property="phone"/>
        <result column="email" property="email"/>
        <result column="avatar" property="avatar"/>
        <result column="status" property="status"/>
        <result column="dept_id" property="deptId"/>
        <result column="last_login_time" property="lastLoginTime"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <!-- 角色列表 -->
        <collection property="roles" ofType="com.lei.mes.vo.user.RoleVO">
            <id column="role_id" property="roleId"/>
            <result column="role_name" property="roleName"/>
            <result column="role_code" property="roleCode"/>
        </collection>
    </resultMap>
    <select id="getUserVoPage" resultMap="userDetailResultMap">
        SELECT u.id, u.username, u.real_name, u.phone, u.email,
        u.avatar, u.status, u.dept_id, ur.role_id,
        r.role_name, r.role_code, u.last_login_time,
        u.created_at, u.updated_at
        FROM sys_user u
        LEFT JOIN sys_user_role ur ON u.id = ur.user_id
        LEFT JOIN sys_role r ON ur.role_id = r.id
        WHERE u.is_delete = 0
        <if test="username != null and username != ''">
            AND (u.username LIKE CONCAT('%', #{username}, '%')
            OR u.real_name LIKE CONCAT('%', #{username}, '%'))
        </if>
        ORDER BY u.created_at DESC
    </select>

</mapper>
